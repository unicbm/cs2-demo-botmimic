<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>DemoTracer</AssemblyName>
    <RootNamespace>DemoTracer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="DemoTracerApi\**\*.cs" />
    <EmbeddedResource Remove="DemoTracerApi\**\*" />
    <None Remove="DemoTracerApi\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.367" />
    <ProjectReference Include="DemoTracerApi\DemoTracerApi.csproj">
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>
</Project>
